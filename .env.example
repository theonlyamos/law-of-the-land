# RAG document search (GroundX) and answer generation (Gemini)
GROUNDX_API_KEY=your_groundx_api_key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Convex (run `bunx convex dev` to create a project and fill these in)
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set in Convex dashboard: npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Used by Better Auth for OAuth redirects (also set SITE_URL in Convex dashboard)
SITE_URL=http://localhost:3000

# Optional OAuth providers (set in Convex dashboard for server-side auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email verification (set in Convex dashboard). Without RESEND_API_KEY,
# verification links are logged to the Convex console instead of emailed —
# fine for dev, required for production sign-ups to work.
RESEND_API_KEY=
EMAIL_FROM="Law of the Land <noreply@yourdomain.com>"

# Billing via Polar (all set in Convex dashboard).
# Limits are enforced only when BILLING_ENABLED=true; usage is counted either way.
# Webhook endpoint: https://<deployment>.convex.site/polar/events
# (events: product.created, product.updated, subscription.created, subscription.updated)
BILLING_ENABLED=false
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_PRO_MONTHLY_PRODUCT_ID=
