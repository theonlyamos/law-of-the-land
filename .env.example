GROUNDX_API_KEY=your_groundx_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
HELICONE_API_KEY=your_helicone_api_key
GOOGLE_AI_API_KEY=your_google_ai_api_key
TAVILY_API_KEY=your_tavily_api_key

# Convex (run `bunx convex dev` to create a project and fill these in)
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# Convex Auth JWT keys — generate with: node scripts/generate-convex-auth-keys.mjs
# Add JWT_PRIVATE_KEY and JWKS to your Convex dashboard environment variables.
JWT_PRIVATE_KEY=
JWKS=

# Optional OAuth providers for Convex Auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Used by Convex Auth for OAuth redirects (local dev example)
SITE_URL=http://localhost:3000
